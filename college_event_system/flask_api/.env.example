# ─────────────────────────────────────────────
# LTSU Events — Flask API Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Google Gemini AI (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI (console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# QR Encryption — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
QR_SECRET_KEY=your_32_byte_hex_secret_here

# Flask secret key — generate with same command above
FLASK_SECRET_KEY=another_random_32_byte_hex_here

# Firebase Admin SDK (recommended)
# Option A (preferred for CI/CD): full service account JSON as one-line string
FIREBASE_SERVICE_ACCOUNT=

# Option B: standard Google credentials env path
GOOGLE_APPLICATION_CREDENTIALS=

# Path relative to flask_api/ or absolute path
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Optional legacy FCM HTTP key (only if an old code path needs it)
FIREBASE_SERVER_KEY=

# Sentry monitoring
# Sentry Flask project → Client Keys (DSN)
SENTRY_DSN=https://your_flask_dsn@o000000.ingest.sentry.io/0000000

# Novu notifications
NOVU_API_KEY=your_novu_api_key_here

# LogSnag event logging
LOGSNAG_TOKEN=your_logsnag_token_here

# Flask environment
FLASK_ENV=development
PORT=5000

# Ollama (runs locally — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
