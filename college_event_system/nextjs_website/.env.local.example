# ─────────────────────────────────────────────────────────────────
# LTSU Events — Next.js Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────────────────────────

# ── Clerk Authentication ──────────────────────────────────────────
# Get from: https://clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase ──────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Cloudinary ────────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ── Resend Email ──────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@ltsuevents.com
RESEND_FROM_NAME=LTSU Events

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────
# Get from: https://upstash.com → Redis Database → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Flask API (Railway) ───────────────────────────────────────────
# Set this after deploying Flask to Railway
# Local development: http://localhost:5000
NEXT_PUBLIC_FLASK_API_URL=https://your-app.railway.app

# ── OpenWeatherMap (Auto Theme) ───────────────────────────────────
# Get from: https://openweathermap.org → My API Keys
OPENWEATHER_API_KEY=your_weather_api_key_here
NEXT_PUBLIC_OPENWEATHER_KEY=your_weather_api_key_here

# ── Sentry (Error Monitoring) ─────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your_public_dsn@o000000.ingest.sentry.io/0000000

# ── Novu (Unified Notifications) ──────────────────────────────────
# Get from: https://web.novu.co → Settings → API Keys
NOVU_API_KEY=your_novu_api_key_here

# ── LogSnag (Event Logging) ───────────────────────────────────────
# Get from: https://logsnag.com → Project Settings → API
LOGSNAG_TOKEN=your_logsnag_token_here

# ── App URL ───────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (set in Vercel dashboard)
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
